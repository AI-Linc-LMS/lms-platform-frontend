# Copy to ".env.local" for local development (Next.js loads .env.local over .env).
# On Netlify: Site settings → Environment variables → add the same NEXT_PUBLIC_* keys.

# --- LMS web app (this Next.js deployment) ---
# Production example: https://your-lms.netlify.app
NEXT_PUBLIC_APP_URL=

# --- Backend API (Django or your LMS API) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Tenant / client (matches your API) ---
NEXT_PUBLIC_CLIENT_ID=1

# --- Google Sign-In (optional) ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- LiveKit (optional; proctoring live stream) ---
NEXT_PUBLIC_LIVEKIT_URL=

# --- OpenTelemetry (optional) ---
# NEXT_PUBLIC_OTEL_SERVICE_NAME=lms-platform-frontend
# NEXT_PUBLIC_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# NEXT_PUBLIC_OTEL_DEBUG=false

# --- Server-only API routes (never expose secrets with NEXT_PUBLIC_) ---
# OPENAI_API_KEY=
# OPENAI_ATS_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1
